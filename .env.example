# Defensor environment variables. Copy to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.

# Anthropic API key for Opus 4.7 + Managed Agents beta.
# Request access at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# URL where the Python agent FastAPI service is reachable.
# Local dev: http://localhost:8000
# Fly.io prod: https://defensor-agents.fly.dev  (set on Day 4)
AGENTS_URL=http://localhost:8000

# Managed Agents beta header (pin this — it gates autonomous follow-up).
ANTHROPIC_BETA=managed-agents-2026-04-01
